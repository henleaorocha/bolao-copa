# Supabase — obter em https://supabase.com/dashboard/project/<ID>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_ID>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>

# Apenas no servidor (nunca expor ao browser)
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>

# URL pública do app (usado para CSRF e redirects)
# Local: http://localhost:3000 | Produção: https://bolao-copa.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API Football — obter em https://dashboard.api-football.com (servidor apenas, nunca NEXT_PUBLIC_)
API_FOOTBALL_KEY=<your-api-football-key>
